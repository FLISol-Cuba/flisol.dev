---
import { eventConfig } from "../data/event";
import { program } from "../data/program";
---

<div class="relative isolate">
  <svg
    class="absolute inset-0 -z-10 h-[80rem] w-full stroke-white/10 [mask-image:radial-gradient(100%_100%_at_top_right,white,transparent)]"
    aria-hidden="true"
  >
    <defs>
      <pattern
        id="1d4240dd-898f-445f-932d-e2872fd12de3"
        width="200"
        height="200"
        x="50%"
        y="0"
        patternUnits="userSpaceOnUse"
      >
        <path d="M.5 200V.5H200" fill="none"></path>
      </pattern>
    </defs>
    <svg x="0" y="0" class="overflow-visible fill-gray-800/20">
      <path d="M-200 0h201v201h-201Z M600 0h201v201h-201Z M-400 600h201v201h-201Z M200 800h201v201h-201Z" stroke-width="0"
      ></path>
    </svg>
    <rect width="100%" height="100%" stroke-width="0" fill="url(#1d4240dd-898f-445f-932d-e2872fd12de3)"></rect>
  </svg>

  <div class="mx-auto pt-16 max-w-7xl px-6 lg:px-8" id="program">
    <div class="max-w-5xl yerro-animate-left">
      <p class="mt-2 text-3xl font-bold tracking-tight text-white sm:text-4xl">Programa</p>
      <!-- <p class="mt-6 text-lg leading-8 text-gray-300">
        No te pierdas ninguna de las charlas que tenemos para tí
      </p> -->
      <p class="mt-6 text-lg leading-8 text-gray-300">
        Aqui iremos actualizando el programa del evento. Mantente al tanto en <a
          class="underline decoration-west-side-500 underline-offset-4 transition hover:text-white"
          href={eventConfig.links.telegram.href}
          target="_blank"
          rel="noreferrer"
        >{eventConfig.links.telegram.inlineLabel}</a>.
      </p>
    </div>
    <div class="mt-16 max-w-2xl sm:mt-20 lg:mt-24 md:max-w-none">
      <dl class="grid max-w-xl grid-cols-1 gap-x-8 gap-y-16 md:max-w-none lg:grid-cols-2 xl:grid-cols-3">
        {
          program.map((presentation) => (
            <div class="flex flex-col yerro-animate-bottom">
              <dt class="text-base items-center mb-4 flex  text-white">
                <div class=" flex items-center h-10 w-10  justify-center rounded-lg bg-west-side-500">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="lucide lucide-circle-check-big"
                  >
                    <>
                      <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                      <path d="m9 11 3 3L22 4" />
                    </>
                  </svg>
                </div>
                <span class="ml-4">{presentation.time}</span>
              </dt>
              <dd class="mt-1 flex  flex-col  leading-7 ">
                <p class="flex-auto text-white text-2xl font-bold">{presentation.title}</p>
                <p class="flex-auto text-base pt-2 text-white">Por {presentation.speaker}</p>
                <p class="flex-auto text-base text-gray-300 pt-3 text-justify">{presentation.description}</p>
              </dd>
            </div>
          ))
        }
      </dl>
    </div>
  </div>
</div>
