---
import { eventConfig } from "../data/event";

const navLinks = [
  { href: "#about", label: "Acerca de" },
  { href: "#program", label: "Programa" },
  { href: "#live", label: "Streaming" },
  { href: "#faq", label: "FAQS" },
  { href: "#editions", label: "Ediciones Pasadas" },
];

const youtubeUrl = eventConfig.links.stream.href.replace("watch?v=", "embed/");
---

<header>
  <div class="absolute top-0 w-full flex justify-center">
    <nav
      class="absolute z-40 mx-auto w-full flex max-w-7xl items-center justify-between p-6 lg:px-8 yerro-animate-top"
      aria-label="Navegación principal"
    >
      <a href="/" class="-m-1.5 p-1.5">
        <span class="sr-only">Flisol</span>
        <img
          class="h-16 w-auto yerro-animate-fade-in"
          src="/flisol-logo.png"
          alt="Logo de Flisol Cuba"
        />
      </a>

      <button
        type="button"
        class="lg:hidden text-white p-2"
        aria-label="Abrir menú"
        aria-expanded="false"
        id="mobile-menu-btn"
      >
        <div id="nav-icon">
          <span></span>
          <span></span>
          <span></span>
        </div>
      </button>

      <div class="hidden lg:flex lg:gap-x-12 text-white items-center">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class="text-sm font-semibold leading-6 hover:text-west-side-400 transition-colors"
            >
              {link.label}
            </a>
          ))
        }
      </div>

      <div class="hidden lg:flex gap-5 items-center">
        <a
          href={youtubeUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-md bg-west-side-500 px-5 py-2 text-sm font-semibold text-white shadow-sm hover:bg-west-side-600 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-west-side-600"
        >
          Ir al Evento
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="inline -mt-1"
            width="15"
            height="15"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M7 7h10v10"></path>
            <path d="M7 17 17 7"></path>
          </svg>
        </a>

        <a href="https://github.com/FLISol-Cuba/flisol.dev" aria-label="GitHub">
          <img src="/github.svg" alt="" class="h-10 w-auto" />
        </a>
      </div>
    </nav>
  </div>

  <div
    class="lg:hidden fixed inset-0 z-30 hidden bg-blue-900/95 backdrop-blur-sm"
    id="mobile-menu"
    role="dialog"
    aria-modal="true"
    aria-label="Menú de navegación"
  >
    <div class="flex flex-col items-center justify-center h-full gap-8">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="text-2xl font-semibold text-white hover:text-west-side-400 transition-colors"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href={youtubeUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-md bg-west-side-500 px-6 py-3 text-lg font-semibold text-white shadow-sm hover:bg-west-side-600"
      >
        Ir al Evento
      </a>
    </div>
  </div>
</header>

<style>
  #nav-icon {
    width: 30px;
    height: 24px;
    position: relative;
    cursor: pointer;
    display: block;
  }

  #nav-icon span {
    display: block;
    position: absolute;
    height: 3px;
    width: 100%;
    background: #d3531a;
    border-radius: 3px;
    opacity: 1;
    left: 0;
    transition: 0.25s ease-in-out;
    transform-origin: center;
  }

  #nav-icon span:nth-child(1) {
    top: 0px;
  }
  #nav-icon span:nth-child(2) {
    top: 10px;
  }
  #nav-icon span:nth-child(3) {
    top: 20px;
  }

  #nav-icon.open span:nth-child(1) {
    transform: rotate(45deg);
    top: 10px;
  }
  #nav-icon.open span:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  #nav-icon.open span:nth-child(3) {
    transform: rotate(-45deg);
    top: 10px;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const btn = document.getElementById("mobile-menu-btn");
    const menu = document.getElementById("mobile-menu");
    const icon = document.getElementById("nav-icon");

    const toggle = () => {
      menu?.classList.toggle("hidden");
      icon?.classList.toggle("open");
    };

    btn?.addEventListener("click", toggle);
  });
</script>
